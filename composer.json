{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "a2zwebltd/brandgeo-laravel-nova",
    "description": "BrandGEO client dashboard for Laravel Nova — AI brand visibility data (brands, audits, monitoring) rendered inside your Nova admin, keyed by your BrandGEO API key.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "nova",
        "brandgeo",
        "dashboard",
        "geo",
        "ai-visibility",
        "brand-monitoring"
    ],
    "homepage": "https://github.com/a2zwebltd/brandgeo-laravel-nova",
    "support": {
        "issues": "https://github.com/a2zwebltd/brandgeo-laravel-nova/issues",
        "source": "https://github.com/a2zwebltd/brandgeo-laravel-nova"
    },
    "authors": [
        {
            "name": "A2Z WEB",
            "homepage": "https://a2zweb.co/"
        },
        {
            "name": "Dawid Makowski",
            "role": "Maintainer",
            "homepage": "https://github.com/makowskid"
        }
    ],
    "require": {
        "php": "^8.2",
        "a2zwebltd/brandgeo-laravel-client": "^1.0",
        "laravel/framework": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.25"
    },
    "suggest": {
        "laravel/nova": "Required to surface the dashboard inside your Nova admin panel (^5.0)."
    },
    "autoload": {
        "psr-4": {
            "A2ZWeb\\BrandGeoNova\\": "src/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.x-dev"
        },
        "laravel": {
            "providers": [
                "A2ZWeb\\BrandGeoNova\\BrandGeoNovaServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "lint": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true
    }
}
